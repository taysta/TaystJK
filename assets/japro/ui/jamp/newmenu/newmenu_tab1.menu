            MAKE_INTERACTIVE(BODY_FULL_X BODY_ROW_18_Y BODY_FULL_W BODY_ROW_H)
            action { play "sound/interface/button1" ; }
        }

        ROW_YESNO(TAB1_PAGE4, 20, "Draw FPS", "Toggle cg_drawFPS", "cg_drawFPS", ACT_NONE)
        ROW_YESNO(TAB1_PAGE4, 21, "Draw Timer", "Toggle cg_drawTimer", "cg_drawTimer", ACT_NONE)
        ROW_YESNO(TAB1_PAGE4, 22, "Dynamic Crosshair", "Toggle cg_dynamicCrosshair", "cg_dynamicCrosshair", ACT_NONE)
        ROW_YESNO(TAB1_PAGE4, 23, "Identify Target", "Toggle cg_crosshairIdentifyTarget", "cg_crosshairIdentifyTarget", ACT_NONE)
        ROW_TEXT(TAB1_PAGE4, 24, "Direct Only", "Nested helper macros are not row arguments")


        // Page 5 - low-level body wrapper fixtures
        ROW_SECTION(TAB1_PAGE5, 1, "Low-Level Body", "Direct ITEM_BODY_* wrappers")

        TEXT_BOX_BODY(tab1_page5_body_generic_label, TAB1_PAGE5, BODY_LABEL_X BODY_ROW_2_Y BODY_COLUMN_W BODY_ROW_H, INVISIBLE, "ITEM_BODY_GENERIC", "Back-compat ACT_NONE body")
