        TEXT_BOX_BODY(tab1_page5_body_button_label, TAB1_PAGE5, BODY_LABEL_X BODY_ROW_7_Y BODY_COLUMN_W BODY_ROW_H, INVISIBLE, "BUTTON_IMPL", "Button alias body")
        itemDef { type ITEM_TYPE_BUTTON ITEM_BODY_BUTTON_IMPL(tab1_page5_body_button, TAB1_PAGE5, BODY_CONTROL_X BODY_ROW_7_Y BODY_COLUMN_W BODY_ROW_H, "ITEM_BODY_BUTTON_IMPL", setcvar ui_newmenu_body_button_impl 1 ;) }

        TEXT_BOX_BODY(tab1_page5_body_generic_cond_label, TAB1_PAGE5, BODY_LABEL_X BODY_ROW_8_Y BODY_COLUMN_W BODY_ROW_H, INVISIBLE, "GENERIC_COND", "Conditional ACT_NONE body")
        itemDef { type ITEM_TYPE_BUTTON ITEM_BODY_GENERIC_COND(tab1_page5_body_generic_cond, TAB1_PAGE5, BODY_CONTROL_X BODY_ROW_8_Y BODY_COLUMN_W BODY_ROW_H, "ITEM_BODY_GENERIC_COND", cvarTest cg_drawFPS showCvar { 0 }) }

        TEXT_BOX_BODY(tab1_page5_body_d_cond_label, TAB1_PAGE5, BODY_LABEL_X BODY_ROW_9_Y BODY_COLUMN_W BODY_ROW_H, INVISIBLE, "D_COND", "Conditional dirty body")
        itemDef { type ITEM_TYPE_BUTTON ITEM_BODY_D_COND(tab1_page5_body_d_cond, TAB1_PAGE5, BODY_CONTROL_X BODY_ROW_9_Y BODY_COLUMN_W BODY_ROW_H, "ITEM_BODY_D_COND", cvarTest cg_dynamicCrosshair enableCvar { 0 }) }

        TEXT_BOX_BODY(tab1_page5_body_dr_cond_label, TAB1_PAGE5, BODY_LABEL_X BODY_ROW_10_Y BODY_COLUMN_W BODY_ROW_H, INVISIBLE, "DR_COND", "Conditional restart body")
        itemDef { type ITEM_TYPE_BUTTON ITEM_BODY_DR_COND(tab1_page5_body_dr_cond, TAB1_PAGE5, BODY_CONTROL_X BODY_ROW_10_Y BODY_COLUMN_W BODY_ROW_H, "ITEM_BODY_DR_COND", cvarTest cg_crosshairIdentifyTarget disableCvar { 1 }) }

        TEXT_BOX_BODY(tab1_page5_body_action_cond_label, TAB1_PAGE5, BODY_LABEL_X BODY_ROW_11_Y BODY_COLUMN_W BODY_ROW_H, INVISIBLE, "ACTION_COND", "Conditional custom action body")
        itemDef { type ITEM_TYPE_BUTTON ITEM_BODY_ACTION_COND_IMPL(tab1_page5_body_action_cond, TAB1_PAGE5, BODY_CONTROL_X BODY_ROW_11_Y BODY_COLUMN_W BODY_ROW_H, "ITEM_BODY_ACTION_COND_IMPL", cvarTest cg_drawTimer hideCvar { 1 }, setcvar ui_newmenu_body_action_cond 1 ;) }

        ITEM_BODY_TEXT_BOX(tab1_page5_direct_text_box, TAB1_PAGE5, BODY_ROW_12_Y, "ITEM_BODY_TEXT_BOX", "Direct body text wrapper")
        ITEM_BODY_TEXT_BOX_EX(tab1_page5_direct_text_box_ex, TAB1_PAGE5, BODY_ROW_13_Y, "ITEM_BODY_TEXT_BOX_EX", "Direct body text EX wrapper", cvarTest cg_drawFPS showCvar { 0 })

        TEXT_BOX_BODY(tab1_page5_text_box_body, TAB1_PAGE5, BODY_FULL_X BODY_ROW_15_Y BODY_FULL_W BODY_ROW_H, INVISIBLE, "TEXT_BOX_BODY", "Direct full text box")
        TEXT_BOX_BODY_EX(tab1_page5_text_box_body_ex, TAB1_PAGE5, BODY_FULL_X BODY_ROW_16_Y BODY_FULL_W BODY_ROW_H, INVISIBLE, "TEXT_BOX_BODY_EX", "Direct full text box EX", cvarTest cg_drawTimer hideCvar { 1 })
        TEXT_BOX_BODY2(tab1_page5_text_box_body2, TAB1_PAGE5, BODY_FULL_X BODY_ROW_18_Y BODY_FULL_W BODY_ROW_H2, INVISIBLE, "TEXT_BOX_BODY2", "Second line", "Direct two-line text box")
