            textalign           ITEM_ALIGN_CENTER
            textalignx          MENU_WIDTH_HALF
            textaligny          BODY_OPTION_OFFSET
            textscale           BODY_OPTION_SCALE
            font                BODY_OPTION_FONT
            forecolor           COL_TEXT_PRIMARY
            backcolor           COL_ROW_CONTROL_BACK
            border              1
            bordercolor         COL_ROW_CONTROL_BORDER
            visible             INVISIBLE
            descText            "Enabled while cg_dynamicCrosshair is 0"
            ROW_COND_ENABLE(cg_dynamicCrosshair, { 0 })
            MAKE_INTERACTIVE(BODY_FULL_X BODY_ROW_17_Y BODY_FULL_W BODY_ROW_H)
            action { play "sound/interface/button1" ; }
        }

        itemDef
        {
            name                tab1_page4_cond_disable
            group               TAB1_PAGE4
            text                "ROW_COND_DISABLE"
            type                ITEM_TYPE_BUTTON
            rect                BODY_FULL_X BODY_ROW_18_Y BODY_FULL_W BODY_ROW_H
