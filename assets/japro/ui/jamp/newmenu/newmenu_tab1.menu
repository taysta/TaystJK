        TEXT_BOX_BODY(tab1_page5_body_action_label, TAB1_PAGE5, BODY_LABEL_X BODY_ROW_5_Y BODY_COLUMN_W BODY_ROW_H, INVISIBLE, "ACTION_IMPL", "Custom action body")
