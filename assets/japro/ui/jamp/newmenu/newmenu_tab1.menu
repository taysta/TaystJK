            "Multi Float",
            "ROW_MULTIFL",
            "ui_fake_multifl",
            { "Low" 0 "Medium" 1 "High" 2 },
            ACT_NONE)

        // MULTI (feeder)
        ROW_MULTI_FEEDER(TAB1_PAGE1, 11,
