            "Checkbox",
            "ROW_CHECKBOX",
            "cg_strafeHelper",
            4,
            ACT_NONE)

        // MULTI (string)
        ROW_MULTI(TAB1_PAGE1, 9,
            "Multi",
            "ROW_MULTI",
            "ui_fake_multi",
            { "Option A" "a" "Option B" "b" "Option C" "c" },
            ACT_NONE)

        // MULTI (float)
